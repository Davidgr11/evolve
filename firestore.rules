rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Users can only read and write their own data
    match /users/{userId}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Invite codes: any authenticated user can read (to join a space) or create
    match /coupleInvites/{code} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
    }

    // Couple documents
    match /couples/{coupleId} {
      // Members can read
      allow read: if request.auth != null &&
        request.auth.uid in resource.data.members;

      // Creator can create (adding themselves as first member)
      allow create: if request.auth != null &&
        request.auth.uid in request.resource.data.members;

      // Members can update; or a non-member can join a 1-member couple by adding themselves
      allow update: if request.auth != null && (
        request.auth.uid in resource.data.members ||
        (
          resource.data.members.size() == 1 &&
          request.auth.uid in request.resource.data.members &&
          request.resource.data.members.size() == 2 &&
          resource.data.members[0] in request.resource.data.members
        )
      );

      // All sub-collections: only members can read/write
      match /{document=**} {
        allow read, write: if request.auth != null &&
          request.auth.uid in get(/databases/$(database)/documents/couples/$(coupleId)).data.members;
      }
    }

    // Deny all other access
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
