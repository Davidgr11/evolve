rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Users can only read and write their own files
    match /users/{userId}/{allPaths=**} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if request.auth != null
                   && request.auth.uid == userId
                   && request.resource.size < 2 * 1024 * 1024;
      allow delete: if request.auth != null && request.auth.uid == userId;
    }

    // Couple shared storage — any authenticated user can read/write/delete
    // (access is implicitly scoped to users who know the coupleId path)
    match /couples/{coupleId}/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
                   && request.resource.size < 2 * 1024 * 1024;
      allow delete: if request.auth != null;
    }

    // Deny all other access
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
